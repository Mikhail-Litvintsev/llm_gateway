APP_NAME=LLM_Gateway
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=mysql
DB_HOST=llm_mysql
DB_PORT=3306
DB_DATABASE=llm_gateway
DB_USERNAME=llm_user
DB_PASSWORD=secret

REDIS_HOST=llm_redis
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MYSQL_ROOT_PASSWORD=root_secret
MYSQL_PASSWORD=secret

# Claude API
ANTHROPIC_API_KEY=

# Admin API key for internal management endpoints (rotation, client provisioning).
# Generate: openssl rand -hex 32
CLAUDE_ADMIN_API_KEY=

CLAUDE_OPUS_MODEL=claude-opus-4-6
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5

# Pepper for client API key hashing (SHA-256 + pepper). Fixed per environment; do not rotate without key-rehash strategy.
API_KEY_PEPPER=

DEV_MODE_LATENCY_MS=150
DEV_MODE_CONTENT="This is a dev_mode stub response."
