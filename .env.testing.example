APP_NAME=LLM_Gateway
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Test database lives on the same MySQL server as dev, on a separate schema.
# Create it once with: php artisan llm:create-test-db
DB_CONNECTION=mysql
DB_HOST=llm_mysql
DB_PORT=3306
DB_DATABASE=llm_gateway_test
DB_USERNAME=llm_user
DB_PASSWORD=secret

REDIS_HOST=llm_redis
REDIS_PORT=6379

# In-memory drivers for fast, isolated tests.
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
LOG_CHANNEL=null

# Claude API placeholders. Tests must not hit real Anthropic — they fake Http or use mocks.
# Integration tests opt in via INTEGRATION_ANTHROPIC=1 and a separate ANTHROPIC_API_KEY_TEST.
ANTHROPIC_API_KEY=sk-ant-test-placeholder
CLAUDE_ADMIN_API_KEY=test-admin
API_KEY_PEPPER=test-pepper

CLAUDE_OPUS_MODEL=claude-opus-4-6
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5
